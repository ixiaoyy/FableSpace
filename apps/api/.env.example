# FableSpace API local environment
# Copy to apps/api/.env for local Python entrypoints.
# Project-root .env is still used by Docker Compose interpolation.

FABLESPACE_STORAGE_BACKEND=database
FABLESPACE_DATABASE_URL=
FABLESPACE_MYSQL_URL=
FABLESPACE_SEED_DEFAULT_SPACES=1
FABLESPACE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Optional system/public-welfare LLM key. Do not commit real keys.
OPENCODE_API_KEY=
