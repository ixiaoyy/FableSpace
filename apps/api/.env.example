# FableSpace API environment example.
# Copy this file to apps/api/.env and fill only the values needed by this deployment.
# The private apps/api/.env file is ignored by Git. Never commit real credentials.

# -----------------------------------------------------------------------------
# Storage and runtime paths
# -----------------------------------------------------------------------------

# Authoritative storage backend: database (default) or json (development/legacy only).
FABLESPACE_STORAGE_BACKEND=database

# Runtime data root. Docker Compose overrides this value to /data and persists it
# in the fablespace_data volume. Leave empty for the local default .fablespace-api.
FABLESPACE_OUTPUT_ROOT=

# Optional one-process frontend/fixture overrides. Keep these commented to retain
# repository defaults; explicitly assigning an empty value disables that path.
# FABLESPACE_FRONTEND_ROOT=apps/web
# FABLESPACE_FIXTURE_FILE=apps/api/src/fablespace_api/core/demo_assets/overpass_demo.json

# Compatibility endpoint used by SillyTavern-related integration helpers.
FABLESPACE_SILLYTAVERN_URL=http://127.0.0.1:8000

# NPC background simulation interval in seconds.
FABLESPACE_SIMULATION_INTERVAL_SECONDS=600

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Primary SQLAlchemy URL. Empty uses <FABLESPACE_OUTPUT_ROOT>/fablespace.sqlite3.
FABLESPACE_DATABASE_URL=

# Production shares the ParallelLines MySQL service but uses its own `fablespace`
# database. The `db` hostname resolves through `parallellines_default`.
# FABLESPACE_DATABASE_URL=mysql+pymysql://appuser:change-me@db:3306/fablespace?charset=utf8mb4

# Legacy database URL alias. New deployments should use FABLESPACE_DATABASE_URL.
FABLESPACE_MYSQL_URL=

# SQLAlchemy pool tuning. Keep SQL logging disabled in production because queries
# may expose user, conversation, or owner configuration data.
FABLESPACE_MYSQL_POOL_SIZE=5
FABLESPACE_MYSQL_MAX_OVERFLOW=10
FABLESPACE_MYSQL_ECHO=false

# Seed and refresh the built-in public-welfare spaces at database startup.
FABLESPACE_SEED_DEFAULT_SPACES=1

# -----------------------------------------------------------------------------
# Shared Redis cache
# -----------------------------------------------------------------------------

# Production reuses the ParallelLines Redis service but reserves logical DB 1.
# Platform discovery statistics and recent-memory results use this shared cache;
# failures fall back to an in-process TTL cache rather than failing requests.
FABLESPACE_REDIS_URL=redis://redis:6379/1

# -----------------------------------------------------------------------------
# Generated files in R2 / S3-compatible storage
# -----------------------------------------------------------------------------

# local keeps generated previews below FABLESPACE_OUTPUT_ROOT and is required by
# ParallelLines private mode. Standalone public deployments may opt into s3/CDN.
FABLESPACE_GENERATED_STORAGE_BACKEND=local

# Production reuses the ParallelLines bucket/account and isolates all objects under
# fablespace/. Never commit real access credentials.
FABLESPACE_S3_BUCKET=
FABLESPACE_S3_REGION=auto
FABLESPACE_S3_ENDPOINT_URL=
FABLESPACE_S3_ACCESS_KEY_ID=
FABLESPACE_S3_SECRET_ACCESS_KEY=
FABLESPACE_S3_PREFIX=fablespace
FABLESPACE_CDN_BASE_URL=
FABLESPACE_S3_REQUEST_TIMEOUT_SECONDS=20

# -----------------------------------------------------------------------------
# Browser access
# -----------------------------------------------------------------------------

# Comma-separated browser origins; this is not a JSON array.
# Add the exact HTTPS production origin before exposing the API publicly.
FABLESPACE_CORS_ORIGINS=https://fable.pingxingxian.space,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# ParallelLines administrator SSO
# -----------------------------------------------------------------------------

# Keep `legacy` for standalone development. Production private-space deployment
# uses `parallellines`, which ignores browser-provided X-User-Id/user_id claims.
FABLESPACE_AUTH_MODE=legacy

# Production backend reaches ParallelLines over the shared Docker network:
# http://api:8000/api/v1
FABLESPACE_PARALLELLINES_API_BASE_URL=http://127.0.0.1:8000/api/v1
FABLESPACE_PARALLELLINES_PUBLIC_BASE_URL=https://pingxingxian.space

# Must match ParallelLines FABLESPACE_SSO_SERVICE_SECRET. Never expose it to Vite.
FABLESPACE_PARALLELLINES_SSO_SERVICE_SECRET=

# Separate random secret for signing FableSpace's own short-lived HttpOnly cookie.
FABLESPACE_SESSION_SECRET=
FABLESPACE_SESSION_COOKIE_NAME=fablespace_session
FABLESPACE_SESSION_COOKIE_SECURE=false
FABLESPACE_SESSION_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Optional model integrations
# -----------------------------------------------------------------------------

# System/public-welfare LLM key used by config/system_public_welfare_llm.json.
# Owner-provided LLM keys belong in the owner configuration flow, not this file.
OPENCODE_API_KEY=

# Hugging Face token used only when the Hugging Face TTS provider is selected.
HF_TOKEN=

# Optional external CrewAI runtime variables. CrewAI is not part of the default
# requirements; leave these commented unless that integration is installed.
# OPENAI_API_KEY=
# MODEL=

# -----------------------------------------------------------------------------
# Deployment/CDN note
# -----------------------------------------------------------------------------

# Static frontend publishing uses the equivalent CDN_S3_* GitHub Secrets and the
# CDN_S3_PREFIX variable. Runtime generated-file storage uses the FABLESPACE_S3_*
# variables above. On the server they may hold the same R2 credentials, but secrets
# remain in apps/api/.env and must never be committed.
