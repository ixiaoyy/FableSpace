# FableSpace Web environment example.
# Copy this file to apps/web/.env.local for local Vite development.
# Every VITE_* value is embedded in browser assets and must be treated as public.

# API base URL. Empty uses same-origin /api through the Vite/nginx proxy.
# For a separated deployment use an absolute base such as https://api.example.com/api.
VITE_API_BASE=

# Optional AMap browser credentials. Restrict them by production web origin in
# the map provider console; never place a server-side API secret here.
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=

# Optional absolute prefix for generated JS/CSS/imported images. Local development
# should leave this empty. The production workflow supplies a release-scoped CDN
# URL such as https://static.example.com/releases/<git-sha> automatically.
VITE_ASSET_BASE_URL=
