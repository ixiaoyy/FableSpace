# FableSpace Web environment example.
# Copy this file to apps/web/.env.local for local Vite development.
# Every VITE_* value is embedded in browser assets and must be treated as public.

# API base URL. Empty uses same-origin /api through the Vite/nginx proxy.
# For a separated deployment use an absolute base such as https://api.example.com/api.
VITE_API_BASE=

# Stable immutable namespace for project-owned images. Do not point this at the
# application origin; image binaries live only in object storage.
VITE_MEDIA_BASE_URL=https://img.pingxingxian.space/fablespace/media/v1
