{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "rootDirs": [
      ".",
      ".react-router/types"
    ],
    "types": [
      "vite/client",
      "node"
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/product/**/*.js",
    "app/product/**/*.jsx",
    ".react-router/types/**/*"
  ]
}
