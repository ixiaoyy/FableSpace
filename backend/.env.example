# FableMap Environment Configuration
# Copy this file to .env and fill in your values

# MySQL Database Configuration
# Leave empty to use JSON file storage (development)
FABLEMAP_MYSQL_URL="mysql+pymysql://user:pass@localhost:3306/fablemap"

# MySQL connection pool settings (optional)
# FABLEMAP_MYSQL_POOL_SIZE=5
# FABLEMAP_MYSQL_MAX_OVERFLOW=10

# Enable SQL echo for debugging (optional)
# FABLEMAP_MYSQL_ECHO=false

# Auto-seed default public welfare taverns
# Set to 0 to disable
FABLEMAP_SEED_DEFAULT_TAVERNS=1

# CORS origins (comma-separated)
# FABLEMAP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173