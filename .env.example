# FableSpace Docker / local deployment environment
# Copy to `.env` before running docker compose if you need to override defaults.
# Legacy `FABLEMAP_*` names are still accepted by the backend as fallbacks, but
# new deployments should use the `FABLESPACE_*` names below.

# Published host ports
FABLESPACE_FRONTEND_PORT=3000
FABLESPACE_API_PORT=8000

# Backend persistence
# Docker Compose reads FABLESPACE_DATABASE_URL from this file and passes it to the
# backend container. Local Python API entrypoints also auto-load project-root
# `.env`; SQLite fallback is only used when neither environment nor `.env`
# provides a database URL.
FABLESPACE_STORAGE_BACKEND=database

# Set a full SQLAlchemy URL for MySQL/Postgres/etc. in `.env`, for example:
# FABLESPACE_DATABASE_URL=mysql+pymysql://user:password@host:3306/fablespace?charset=utf8mb4
FABLESPACE_DATABASE_URL=

# Legacy MySQL URL alias; prefer FABLESPACE_DATABASE_URL for new deployments.
FABLESPACE_MYSQL_URL=
FABLESPACE_SEED_DEFAULT_SPACES=1

# Browser/API origins used by local deployments.
FABLESPACE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend build-time API base.
# Leave empty to use same-origin `/api` paths through nginx.
VITE_API_BASE=

# Optional frontend map provider keys.
# Only set these when using the AMap adapter in browser builds.
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=

# Owner LLM API keys are normally configured per owner/space inside FableSpace,
# not in this shared deployment env file.
#
# Exception: built-in system/public-welfare taverns may hydrate the versioned
# OpenCode Zen DeepSeek V4 Flash Free test config from OPENCODE_API_KEY.
# Leave empty to keep the local no-key rules fallback.
# Do not commit a real provider key.
OPENCODE_API_KEY=

# The system/public-welfare OpenCode config is versioned at:
# backend/config/system_public_welfare_llm.json
#
# Legacy/local free-LLM key names kept here for old local scripts/configs.
# Current runtime code does not read these directly; prefer OPENCODE_API_KEY
# plus the versioned config above.
FABLESPACE_DEFAULT_FREE_LLM_PROVIDER=opencode
FABLESPACE_DEFAULT_FREE_LLM_BACKEND=custom
FABLESPACE_DEFAULT_FREE_LLM_MODEL=deepseek-v4-flash-free
FABLESPACE_DEFAULT_FREE_LLM_BASE_URL=https://opencode.ai/zen
FABLESPACE_DEFAULT_FREE_LLM_API_KEY_ENV=OPENCODE_API_KEY

# Deprecated Kilo local leftovers. Keep blank unless you are intentionally
# running old local scripts/configs outside the current code path.
KILO_API_KEY=
KILO_BASE_URL=
KILO_MODEL=
