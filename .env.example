# Docker Compose interpolation values. Copy to .env for local overrides.

# Local defaults keep the original public ports. Shared production uses
# 127.0.0.1:8950 for the API to avoid the ParallelLines port 8000 binding.
FABLESPACE_API_BIND=8000
FABLESPACE_WEB_BIND=3000

# Required only with deploy/docker-compose.shared.yml.
FABLESPACE_SHARED_NETWORK=parallellines_default

# Frontend build-time values forwarded by docker-compose.yml.
VITE_API_BASE=
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=
VITE_MEDIA_BASE_URL=https://img.pingxingxian.space/fablespace/media/v1
