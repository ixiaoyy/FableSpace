# FableMap Docker / local deployment environment
# Copy to `.env` before running docker compose if you need to override defaults.

# Published host ports
FABLEMAP_FRONTEND_PORT=3000
FABLEMAP_API_PORT=8000

# Backend persistence
# Docker Compose reads FABLEMAP_DATABASE_URL from this file and passes it to the
# backend container. Local Python API entrypoints also auto-load project-root
# `.env`; SQLite fallback is only used when neither environment nor `.env`
# provides a database URL.
FABLEMAP_STORAGE_BACKEND=database

# Set a full SQLAlchemy URL for MySQL/Postgres/etc. in `.env`, for example:
# FABLEMAP_DATABASE_URL=mysql+pymysql://user:password@host:3306/fablemap?charset=utf8mb4
FABLEMAP_DATABASE_URL=

# Legacy alias; prefer FABLEMAP_DATABASE_URL for new deployments.
FABLEMAP_MYSQL_URL=
FABLEMAP_SEED_DEFAULT_TAVERNS=1

# Browser/API origins used by local deployments.
FABLEMAP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend build-time API base.
# Leave empty to use same-origin `/api` paths through nginx.
VITE_API_BASE=

# Optional frontend map provider keys.
# Only set these when using the AMap adapter in browser builds.
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=

# Owner LLM API keys are normally configured per owner/tavern inside FableMap,
# not in this shared deployment env file.
#
# Exception: built-in system/public-welfare taverns may hydrate the versioned
# OpenCode Zen DeepSeek V4 Flash Free test config from OPENCODE_API_KEY.
# Leave empty to keep the local no-key rules fallback.
# Do not commit a real provider key.
OPENCODE_API_KEY=

# The system/public-welfare OpenCode config is versioned at:
# backend/config/system_public_welfare_llm.json
#
# Legacy/local free-LLM key names kept here so `.env.example` covers the same
# key set as existing private `.env` files. Current runtime code does not read
# these directly; prefer OPENCODE_API_KEY plus the versioned config above.
FABLEMAP_DEFAULT_FREE_LLM_PROVIDER=opencode
FABLEMAP_DEFAULT_FREE_LLM_BACKEND=custom
FABLEMAP_DEFAULT_FREE_LLM_MODEL=deepseek-v4-flash-free
FABLEMAP_DEFAULT_FREE_LLM_BASE_URL=https://opencode.ai/zen
FABLEMAP_DEFAULT_FREE_LLM_API_KEY_ENV=OPENCODE_API_KEY

# Deprecated Kilo local leftovers. Keep blank unless you are intentionally
# running old local scripts/configs outside the current code path.
KILO_API_KEY=
KILO_BASE_URL=
KILO_MODEL=
